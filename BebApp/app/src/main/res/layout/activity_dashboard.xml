<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beb_fondo"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/barraSuperior"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/beb_blanco"
        android:elevation="2dp"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:contentDescription="@string/app_name"
                android:src="@mipmap/ic_launcher" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textColor="@color/beb_texto_principal"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtNombreUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxWidth="120dp"
                android:singleLine="true"
                android:text="Usuario"
                android:textColor="@color/beb_texto_secundario"
                android:textSize="13sp" />

            <ImageButton
                android:id="@+id/btnCerrarSesion"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Cerrar sesion"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel" />
        </LinearLayout>
    </com.google.android.material.appbar.MaterialToolbar>

    <FrameLayout
        android:id="@+id/contenedorPrincipal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/navegacionInferior"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/beb_blanco"
        app:itemIconTint="@color/beb_texto_secundario"
        app:itemTextColor="@color/beb_texto_secundario"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_navegacion_inferior" />

</LinearLayout>
