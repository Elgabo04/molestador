<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@color/beb_blanco"
    android:elevation="1dp"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/txtTituloHistorial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/beb_texto_principal"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtDescripcionHistorial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/beb_texto_secundario"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/txtFechaHistorial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/beb_texto_secundario"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/txtFechaAnteriorHistorial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/beb_texto_secundario"
        android:textSize="13sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/txtEstadoHistorial"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingStart="10dp"
        android:paddingTop="5dp"
        android:paddingEnd="10dp"
        android:paddingBottom="5dp"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
